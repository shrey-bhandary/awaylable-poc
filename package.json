{
  "name": "awaylable-va-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Phase-based POC for a phone-calling voice agent with LiveKit + ADK + Gemini + Sarvam",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:cli": "tsx src/main.ts",
    "dev:web": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:web": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "demo": "APP_MODE=mock tsx src/main.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "livekit-server-sdk": "^2.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
