# Phase 2 - web call console mode
APP_MODE=web
WEB_PORT=3000
DATA_DIR=data

# Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0-flash
STT_TIMEOUT_MS=6000
LLM_TIMEOUT_MS=12000
TTS_TIMEOUT_MS=8000
STAGE_RETRY_COUNT=1

# Sarvam STT/TTS
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_PATH=/v1/speech-to-text
SARVAM_TTS_PATH=/text-to-speech
SARVAM_VOICE=shubh


# LiveKit placeholders (used in later phase wiring)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM_PREFIX=awaylable-live

# Exotel vSIP (Phase 2)
EXOTEL_ENABLED=false
EXOTEL_LIVE_ONLY_MODE=false
EXOTEL_SUBDOMAIN=
EXOTEL_SIP_DOMAIN=
EXOTEL_WEBHOOK_SECRET=
EXOTEL_ENFORCE_SIGNATURE=false
EXOTEL_REPLAY_WINDOW_SECONDS=300
EXOTEL_MAX_FUTURE_SKEW_SECONDS=120

# Mock call settings
MOCK_CALLER=+919900000000
MOCK_CALLEE=Awaylable Reception
